{
  "name": "nestmatch",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "npm run dev --workspace=@nestmatch/web",
    "dev:mobile": "npm run dev --workspace=@nestmatch/mobile",
    "build:web": "npm run build --workspace=@nestmatch/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "postinstall": "node apps/mobile/scripts/patch-expo-router.js"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  }
}
