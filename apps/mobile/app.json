{
  "expo": {
    "name": "NestMatch",
    "slug": "nestmatch",
    "owner": "patrob316",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nestmatch",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fcf2d9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nestmatch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NestMatch needs camera access to take photos for your profile and listings.",
        "NSPhotoLibraryUsageDescription": "NestMatch needs photo library access to upload photos for your profile and listings.",
        "NSLocationWhenInUseUsageDescription": "NestMatch uses your location to find nearby listings and roommates.",
        "ITSAppUsesNonExemptEncryption": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fcf2d9"
      },
      "package": "com.nestmatch.app",
      "edgeToEdgeEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-router", { "root": "./app" }],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "NestMatch needs access to your photos to add images to your listing."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd37f25d-5e31-441a-9406-512081552465"
      }
    }
  }
}
